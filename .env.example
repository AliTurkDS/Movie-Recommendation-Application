# Copy this file to ".env" and fill in the values below.

# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Base URL of your deployed Vercel cloud-sync function (see backend/README.md).
# Leave blank to disable cloud backup/restore. The /api/data endpoint is appended.
SYNC_BASE_URL=https://your-deployment.vercel.app
